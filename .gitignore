# Log file rules
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependency folders only
node_modules
.pnp
.pnp.js

# Build output files
dist
dist-ssr
build
*.local

# Env file rules
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel deploy files
.vercel
.vercel.json.backup

# Test artifact files
coverage
.nyc_output
.vitest

# Editor files only
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS artifact files
Thumbs.db
.DS_Store
*~

# Cache files only
.cache
.parcel-cache
.eslintcache
.stylelintcache

# Temp file rules
*.tmp
*.temp
tmp/
temp/

# Package manager files
.yarn/
.pnpm-debug.log

# TypeScript cache files
*.tsbuildinfo

# Vite cache files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
